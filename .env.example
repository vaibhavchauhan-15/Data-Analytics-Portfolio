# Resend — contact form email delivery (https://resend.com)
RESEND_API_KEY=

# Optional — raises GitHub API rate limit for the GitHub Activity section
GITHUB_TOKEN=

# Address that contact-form submissions are delivered to
CONTACT_TO_EMAIL=vaibhav1chauhan12353@gmail.com

# Sender address for outgoing mail (owner notification + visitor acknowledgment).
# Must be an address on a domain you've verified in Resend. Defaults to Resend's
# shared "onboarding@resend.dev" when unset, but in test mode the acknowledgment
# only delivers to the account owner — set a verified-domain address to reply to
# visitors, e.g. "Vaibhav Chauhan <contact@mealmitra.online>".
CONTACT_FROM_EMAIL=Vaibhav Chauhan <contact@mealmitra.online>
