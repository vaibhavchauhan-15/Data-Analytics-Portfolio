# Cloudflare Pages / npm: tolerate the peerOptional conflict between
# @cloudflare/next-on-pages (@cloudflare/workers-types ^4) and newer wrangler
# (@cloudflare/workers-types ^5). Without this, `npx @cloudflare/next-on-pages`
# fails during the Cloudflare build with an ERESOLVE error.
legacy-peer-deps=true
